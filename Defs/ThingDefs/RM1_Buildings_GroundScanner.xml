<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Vanilla GPS: Steel=150, CompInd=4, CompSpacer=1, power=700W, scanFindMtbDays=3, scanFindGuaranteedDays=6 -->
  <!-- Each tier: scanFindMtbDays and scanFindGuaranteedDays ÷ 1.3, Steel ×1.2, CompInd +1 per tier -->
  <!-- CompSpacer stays at vanilla level (1) across all tiers -->

  <ThingDef ParentName="BuildingBase">
    <defName>RM1_GroundScanner_I</defName>
    <label>ground-penetrating scanner I</label>
    <description>An improved ground scanner with enhanced signal processing. Tier 1 of 3.</description>
    <graphicData>
      <texPath>Things/Building/Misc/GroundPenetratingScanner</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>2.65</drawSize>
      <drawRotated>false</drawRotated>
      <drawOffset>(0,0,-0.05)</drawOffset>
      <shadowData>
        <volume>(1.6875, 0.375, 2.125)</volume>
        <offset>(0,0,-0.12)</offset>
      </shadowData>
    </graphicData>
    <building>
      <destroySound>BuildingDestroyed_Metal_Big</destroySound>
    </building>
    <costList>
      <Steel>165</Steel>
      <ComponentIndustrial>5</ComponentIndustrial>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <comps>
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>700</basePowerConsumption>
      </li>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_ScannerMineralsDeep">
        <scanSpeedStat>ResearchSpeed</scanSpeedStat>
        <scanFindMtbDays>2.31</scanFindMtbDays>
        <scanFindGuaranteedDays>4.62</scanFindGuaranteedDays>
        <soundWorking>ScannerGroundPenetrating_Ambience</soundWorking>
      </li>
    </comps>
    <altitudeLayer>Building</altitudeLayer>
    <canBeUsedUnderRoof>false</canBeUsedUnderRoof>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <WorkToBuild>12000</WorkToBuild>
      <Flammability>0.5</Flammability>
      <Beauty>-8</Beauty>
    </statBases>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,2)</interactionCellOffset>
    <interactionCellIcon>DiningChair</interactionCellIcon>
    <interactionCellIconReverse>true</interactionCellIconReverse>
    <fillPercent>0.40</fillPercent>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <designationCategory>Misc</designationCategory>
    <rotatable>true</rotatable>
    <canOverlapZones>false</canOverlapZones>
    <size>(3,3)</size>
    <defaultPlacingRot>South</defaultPlacingRot>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <placeWorkers>
      <li>PlaceWorker_NotUnderRoof</li>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
    <constructionSkillPrerequisite>10</constructionSkillPrerequisite>
    <researchPrerequisites><li>RM1_GroundScanner_T2_Research</li></researchPrerequisites>
  </ThingDef>

