<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Vanilla LRMS: Steel=200, CompInd=6, CompSpacer=2, power=700W, scanFindMtbDays=4, scanFindGuaranteedDays=8 -->
  <!-- Each tier: scanFindMtbDays and scanFindGuaranteedDays ÷ 1.3, Steel ×1.2, CompInd +1 per tier -->
  <!-- CompSpacer stays at vanilla level (2) across all tiers -->

  <ThingDef ParentName="BuildingBase">
    <defName>RM1_MineralScanner_I</defName>
    <label>long-range mineral scanner I</label>
    <description>An improved long-range mineral scanner with enhanced signal processing. Tier 1 of 3.</description>
    <graphicData>
      <texPath>Things/Building/Misc/LongRangeMineralScanner</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(4, 4)</drawSize>
      <shadowData>
        <volume>(1.4, 0.4, 1.4)</volume>
        <offset>(0,0,-0.1)</offset>
      </shadowData>
    </graphicData>
    <building>
      <destroySound>BuildingDestroyed_Metal_Big</destroySound>
    </building>
    <costList>
      <Steel>220</Steel>
      <ComponentIndustrial>7</ComponentIndustrial>
      <ComponentSpacer>2</ComponentSpacer>
    </costList>
    <comps>
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>700</basePowerConsumption>
      </li>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_LongRangeMineralScanner">
        <scanSpeedStat>ResearchSpeed</scanSpeedStat>
        <scanFindMtbDays>3.08</scanFindMtbDays>
        <scanFindGuaranteedDays>6.15</scanFindGuaranteedDays>
        <soundWorking>ScannerLongRangeMineral_Ambience</soundWorking>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_NotUnderRoof</li>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
    <altitudeLayer>Building</altitudeLayer>
    <canBeUsedUnderRoof>false</canBeUsedUnderRoof>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <WorkToBuild>10000</WorkToBuild>
      <Flammability>0.5</Flammability>
      <Beauty>-8</Beauty>
    </statBases>
    <fillPercent>0.40</fillPercent>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <designationCategory>Misc</designationCategory>
    <rotatable>true</rotatable>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,2)</interactionCellOffset>
    <interactionCellIcon>DiningChair</interactionCellIcon>
    <interactionCellIconReverse>true</interactionCellIconReverse>
    <defaultPlacingRot>South</defaultPlacingRot>
    <canOverlapZones>false</canOverlapZones>
    <size>(3, 3)</size>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <constructionSkillPrerequisite>10</constructionSkillPrerequisite>
    <researchPrerequisites><li>RM1_MineralScanner_T2_Research</li></researchPrerequisites>
  </ThingDef>

