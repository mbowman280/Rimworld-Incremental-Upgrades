  <ThingDef ParentName="RM1_Autocannon_Base">
    <defName>RM1_Autocannon_Mark_I</defName>
    <label>autocannon turret Mark I</label>
    <description>An upgraded autocannon with improved shell feed and reinforced barrel. Tier 1 of 3.</description>
    <statBases><MaxHitPoints>420</MaxHitPoints><Flammability>0.63</Flammability></statBases>
    <costList><Steel>360</Steel><Plasteel>48</Plasteel><ComponentIndustrial>8</ComponentIndustrial></costList>
    <comps>
      <li Class="CompProperties_Refuelable">
        <fuelLabel>Shots until barrel change</fuelLabel>
        <fuelGizmoLabel>Barrel durability</fuelGizmoLabel>
        <outOfFuelMessage>Needs new barrel</outOfFuelMessage>
        <fuelFilter><thingDefs><li>Steel</li></thingDefs></fuelFilter>
        <fuelCapacity>100</fuelCapacity>
        <fuelMultiplier>0.5</fuelMultiplier>
        <initialFuelPercent>1</initialFuelPercent>
        <autoRefuelPercent>0.5</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <minimumFueledThreshold>1</minimumFueledThreshold>
        <factorByDifficulty>true</factorByDifficulty>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <fuelIconPath>UI/Overlays/Barrel</fuelIconPath>
      </li>
    </comps>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
    <building><turretGunDef>RM1_Gun_Autocannon_Mark_I</turretGunDef><turretBurstCooldownTime>1.95</turretBurstCooldownTime></building>
    <researchPrerequisites><li>RM1_Autocannon_T2_Research</li></researchPrerequisites>
  </ThingDef>

