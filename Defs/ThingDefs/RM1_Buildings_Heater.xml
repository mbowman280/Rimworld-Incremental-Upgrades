<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Vanilla Heater: Steel=50, CompInd=1, power=175W, energyPerSecond=21 -->
  <!-- Each tier: energyPerSecond ×1.2, Steel ×1.2, CompInd +1 per tier; power stays at 175W; no CompSpacer -->

  <ThingDef ParentName="BuildingBase">
    <defName>RM1_Heater_I</defName>
    <label>heater I</label>
    <description>An improved heater with more efficient combustion. Tier 1 of 3.</description>
    <thingClass>Building_Heater</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <texPath>Things/Building/Misc/TempControl/Heater</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shadowData>
        <volume>(0.5,0.5,0.5)</volume>
      </shadowData>
    </graphicData>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories><li>BuildingsMisc</li></thingCategories>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>42</pathCost>
    <fillPercent>0.25</fillPercent>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>1000</WorkToBuild>
      <Mass>3</Mass>
      <Flammability>1.0</Flammability>
    </statBases>
    <size>(1,1)</size>
    <tickerType>Rare</tickerType>
    <costList>
      <Steel>55</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>175</basePowerConsumption>
        <shortCircuitInRain>true</shortCircuitInRain>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="CompProperties_TempControl">
        <energyPerSecond>75.6</energyPerSecond>
      </li>
      <li Class="CompProperties_Glower">
        <glowRadius>3</glowRadius>
        <glowColor>(255,150,100,0)</glowColor>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_Heater</li>
    </placeWorkers>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>Temperature</designationCategory>
    <constructionSkillPrerequisite>7</constructionSkillPrerequisite>
    <researchPrerequisites><li>RM1_Heater_T2_Research</li></researchPrerequisites>
  </ThingDef>

