<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Vanilla MoisturePump: Steel=75, CompInd=4, power=150W, daysToRadius=60, radius=6.9 -->
  <!-- Each tier: daysToRadius ÷ 1.3 (rounded), Steel ×1.2, CompInd +1 per tier           -->
  <!-- All tiers re-installable (minifiedDef + uninstallWork), no shortCircuitInRain       -->

  <ThingDef ParentName="BuildingBase">
    <defName>RM1_MoisturePump_I</defName>
    <label>moisture pump I</label>
    <description>An improved moisture pump with accelerated osmotic systems. Tier 1 of 3.</description>
    <thingClass>Building</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <texPath>Things/Building/Misc/MoisturePump</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shadowData>
        <volume>(0.58, 0.35, 0.25)</volume>
        <offset>(0,0,-0.1)</offset>
      </shadowData>
    </graphicData>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories><li>BuildingsMisc</li></thingCategories>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>30</pathCost>
    <fillPercent>0.15</fillPercent>
    <specialDisplayRadius>6.9</specialDisplayRadius>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <WorkToBuild>1500</WorkToBuild>
      <Flammability>0.7</Flammability>
      <Mass>50</Mass>
    </statBases>
    <tickerType>Rare</tickerType>
    <building>
      <uninstallWork>1800</uninstallWork>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
      <ai_chillDestination>false</ai_chillDestination>
    </building>
    <costList>
      <Steel>83</Steel>
      <ComponentIndustrial>5</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>150</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="CompProperties_TerrainPumpDry">
        <soundWorking>MoisturePump_Ambience</soundWorking>
        <radius>6.9</radius>
        <daysToRadius>46</daysToRadius>
      </li>
    </comps>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <designationCategory>Misc</designationCategory>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
    <researchPrerequisites><li>RM1_MoisturePump_T2_Research</li></researchPrerequisites>
  </ThingDef>

