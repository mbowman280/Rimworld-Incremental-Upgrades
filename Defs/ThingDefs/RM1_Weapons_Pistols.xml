  <ThingDef ParentName="RM1_Gun_Autopistol_Base">
    <defName>RM1_Gun_Autopistol_I</defName>
    <label>autopistol (Mark I)</label>
    <description>An improved autopistol. Refined tolerances and a polished feed mechanism improve reliability and ballistic performance. Tier 1 of 3.</description>
    <statBases>
      <WorkToMake>6000</WorkToMake>
      <Mass>1.0</Mass>
      <AccuracyTouch>0.96</AccuracyTouch>
      <AccuracyShort>0.84</AccuracyShort>
      <AccuracyMedium>0.48</AccuracyMedium>
      <AccuracyLong>0.36</AccuracyLong>
      <RangedWeapon_Cooldown>0.80</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>36</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <researchPrerequisite>RM1_Autopistol_I_Research</researchPrerequisite>
      <skillRequirements>
        <Crafting>6</Crafting>
      </skillRequirements>
      <recipeUsers>
        <li>TableMachining</li>
      </recipeUsers>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>RM1_Bullet_Autopistol_I</defaultProjectile>
        <warmupTime>0.24</warmupTime>
        <range>31.1</range>
        <soundCast>Shot_Autopistol</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>6</muzzleFlashScale>
