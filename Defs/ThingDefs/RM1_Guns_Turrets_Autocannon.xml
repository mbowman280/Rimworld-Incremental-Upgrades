<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BaseWeaponTurret" Name="RM1_AutocannonGun_Base" Abstract="True">
    <defName>RM1_AutocannonGun_Base</defName>
    <label>autocannon</label>
    <description>An upgraded autocannon weapon assembly designed to attach to a turret.</description>
    <graphicData>
      <texPath>Things/Building/Security/TurretAutocannon_Top</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <techLevel>Industrial</techLevel>
    <statBases>
      <AccuracyTouch>0.28</AccuracyTouch>
      <AccuracyShort>0.72</AccuracyShort>
      <AccuracyMedium>0.66</AccuracyMedium>
      <AccuracyLong>0.50</AccuracyLong>
      <RangedWeapon_Cooldown>3.5</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>40</Mass>
      <Flammability>0</Flammability>
    </statBases>
  </ThingDef>

  <ThingDef ParentName="RM1_AutocannonGun_Base">
