  <ThingDef ParentName="RM1_MiniTurret_Base">
    <defName>RM1_MiniTurret_Mark_I</defName>
    <label>mini-turret Mark I</label>
    <description>An upgraded mini-turret with improved barrel lining and fire control. Tier 1 of 3.</description>
    <statBases><MaxHitPoints>120</MaxHitPoints><Flammability>0.63</Flammability></statBases>
    <costList><Steel>120</Steel><ComponentIndustrial>4</ComponentIndustrial></costList>
    <comps>
      <li Class="CompProperties_Refuelable">
        <fuelLabel>Shots until barrel change</fuelLabel>
        <fuelGizmoLabel>Barrel durability</fuelGizmoLabel>
        <outOfFuelMessage>Needs new barrel</outOfFuelMessage>
        <fuelFilter><thingDefs><li>Steel</li></thingDefs></fuelFilter>
        <fuelCapacity>66</fuelCapacity>
        <fuelMultiplier>0.75</fuelMultiplier>
        <initialFuelPercent>1</initialFuelPercent>
        <autoRefuelPercent>0.5</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <minimumFueledThreshold>1</minimumFueledThreshold>
        <factorByDifficulty>true</factorByDifficulty>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <fuelIconPath>UI/Overlays/Barrel</fuelIconPath>
      </li>
    </comps>
    <constructionSkillPrerequisite>7</constructionSkillPrerequisite>
    <building><turretGunDef>RM1_Gun_MiniTurret_Mark_I</turretGunDef><turretBurstCooldownTime>1.8</turretBurstCooldownTime></building>
    <researchPrerequisites><li>RM1_MiniTurret_T2_Research</li></researchPrerequisites>
  </ThingDef>

