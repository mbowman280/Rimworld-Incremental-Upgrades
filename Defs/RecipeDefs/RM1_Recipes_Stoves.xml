  <!-- Bulk psychite tea x4 — available on both upgraded stoves after vanilla PsychiteTea research -->
  <RecipeDef>
    <defName>RM1_Make_PsychiteTeaBulk</defName>
    <label>make psychite tea x4</label>
    <description>Brew four cups of psychite tea at once.</description>
    <jobString>Brewing psychite tea.</jobString>
    <workAmount>3200</workAmount>
    <workSpeedStat>CookSpeed</workSpeedStat>
    <requiredGiverWorkType>Cooking</requiredGiverWorkType>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_CookMeal</soundWorking>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>PsychoidLeaves</li>
          </thingDefs>
        </filter>
        <count>16</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>PsychoidLeaves</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <PsychiteTea>4</PsychiteTea>
    </products>
    <skillRequirements>
      <Cooking>3</Cooking>
    </skillRequirements>
    <researchPrerequisite>PsychoidBrewing</researchPrerequisite>
    <recipeUsers>
      <li>RM1_ElectricStoveII</li>
      <li>RM1_ElectricStoveIII</li>
    </recipeUsers>
    <displayPriority>425</displayPriority>
  </RecipeDef>

