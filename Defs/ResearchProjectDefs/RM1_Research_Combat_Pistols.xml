  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>RM1_MachinePistol_III_Research</defName>
    <tab>RM1_CombatUpgrades</tab>
    <label>machine pistol upgrade III</label>
    <description>The apex of compact automatic weapons. Advanced fabrication techniques push the machine pistol into near-spacer performance territory.</description>
    <baseCost>3000</baseCost>
    <techLevel>Spacer</techLevel>
    <prerequisites>
      <li>RM1_MachinePistol_II_Research</li>
      <li>AdvancedFabrication</li>
