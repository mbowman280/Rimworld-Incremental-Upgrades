  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>RM1_MachinePistol_II_Research</defName>
    <tab>RM1_CombatUpgrades</tab>
    <label>machine pistol upgrade II</label>
    <description>Advanced materials and a redesigned bolt group reduce cycle time and improve hit probability.</description>
    <baseCost>2000</baseCost>
    <techLevel>Industrial</techLevel>
    <prerequisites><li>RM1_MachinePistol_I_Research</li></prerequisites>
