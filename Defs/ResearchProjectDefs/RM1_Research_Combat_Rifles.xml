    <researchViewY>0.0</researchViewY>
  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>RM1_AssaultRifle_III_Research</defName>
    <tab>RM1_CombatUpgrades</tab>
    <label>assault rifle upgrade III</label>
