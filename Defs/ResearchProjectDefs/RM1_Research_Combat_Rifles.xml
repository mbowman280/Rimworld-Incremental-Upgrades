<Defs>

  <!-- ===== Assault Rifle ===== -->
  <ResearchProjectDef>
    <defName>RM1_AssaultRifle_I_Research</defName>
    <tab>RM1_CombatUpgrades</tab>
    <label>assault rifle upgrade I</label>
    <description>A free-floating barrel and improved gas system lift the assault rifle's performance above standard manufacture.</description>
