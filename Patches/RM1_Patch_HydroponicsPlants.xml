<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Add a custom sow tag RM1_AdvancedHydroponic to all vanilla hydroponic plants  -->
  <!-- so that T5/T6 basins (which use this tag) can still grow them.                -->
  <!-- Corn, haygrass, and devilstrand get ONLY this tag so they are exclusive to T5/T6. -->

  <!-- Vanilla hydroponic plants — add RM1_AdvancedHydroponic so they grow in T5/T6 too -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Rice"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Potato"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Strawberry"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Cotton"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Healroot"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Hops"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Smokeleaf"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Psychoid"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Tinctoria"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>

  <!-- T5/T6-exclusive crops — only get RM1_AdvancedHydroponic (not Hydroponic) -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Corn"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Haygrass"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="Plant_Devilstrand"]/plant/sowTags</xpath>
    <value><li>RM1_AdvancedHydroponic</li></value>
  </Operation>

</Patch>
